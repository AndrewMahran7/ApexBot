# ── Environment & Secrets ──
.env
.env.*
!.env.example
*.pem
*.key

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
venv/
env/
.Python
.pytest_cache/

# ── IDE ──
.vscode/
.idea/
*.swp
*~

# ── OS ──
.DS_Store
ehthumbs.db
Thumbs.db

# ── Logs (regenerated on each run) ──
logs/*.log
logs/diag/

# ── Large data files (not versioned; download separately) ──
data/*.csv

# ── Result artifacts (regenerated; keep JSON summaries via git add -f) ──
results/*.csv
results/*.png

# ── Screenshots / local artifacts ──
screenshots/
*.png.tmp
